# 이 파일을 복사해 .env로 저장하고 실제 값을 채우세요. .env는 git에 커밋되지 않습니다.

# YouTube Data API v3 키 — Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > API 키
YOUTUBE_API_KEY=

# Groq API 키 — https://console.groq.com/keys (무료, 카드 등록 불필요)
GROQ_API_KEY=

# 카카오 REST API 키 — 카카오 디벨로퍼스 앱의 REST API 키
KAKAO_REST_API_KEY=
# 클라이언트 시크릿이 활성화된 앱이면 필요 (플랫폼 키 > REST API 키 카드 > 클라이언트 시크릿)
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost

# 노션 Internal Integration 토큰 — https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_DB_ID=a716cf87-680b-40a2-a5b8-cc9792773f4c

# GitHub Actions에서 자동으로 설정됨 (로컬 테스트 시에는 비워도 됨)
GITHUB_RAW_BASE=
